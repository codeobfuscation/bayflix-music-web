# Bayflix.MS local secrets template
# Copy to .env and fill in real values. .env is gitignored.

# ---------------------------------------------------------------------------
# Cloudflare (account that owns the bayflix.ms zone + Workers)
# Token needs: Zone.DNS Edit, Zone.SSL Edit, Workers Scripts Edit, Workers Routes Edit
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# Google OAuth (better-auth: Google provider)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://auth.<your-domain>/api/auth/callback/google
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Discord OAuth (better-auth: Discord provider)
# Create at https://discord.com/developers/applications
# Redirect URI: https://auth.<your-domain>/api/auth/callback/discord
# Scopes: identify email guilds.join
# ---------------------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Resend (transactional email — optional, used for email verification)
# ---------------------------------------------------------------------------
# RESEND_API_KEY=

# ---------------------------------------------------------------------------
# PocketBase superuser (sync DB) — local convenience copy.
# The authoritative copy lives on the VPS at /srv/bayflix-music/.env.
# ---------------------------------------------------------------------------
PB_ADMIN_EMAIL=
PB_ADMIN_PASS=

# ---------------------------------------------------------------------------
# better-auth
# Generate secret: openssl rand -base64 48
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://auth.bayflix.ms
